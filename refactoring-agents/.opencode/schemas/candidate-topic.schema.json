{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/refactoring-agents/candidate-topic.schema.json",
  "title": "Refactoring Council Candidate Topic",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "summary",
    "evidence",
    "likely_files",
    "supporting_roles",
    "objections",
    "consensus_level",
    "safety_veto",
    "constraints",
    "verification",
    "risk",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^T[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 8
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "likely_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supporting_roles": {
      "type": "array",
      "items": {
        "enum": [
          "code-smell",
          "architecture",
          "safety",
          "testability",
          "roi"
        ]
      }
    },
    "objections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "objection", "resolved"],
        "properties": {
          "role": {
            "type": "string"
          },
          "objection": {
            "type": "string"
          },
          "resolved": {
            "type": "boolean"
          }
        }
      }
    },
    "consensus_level": {
      "enum": ["A", "B", "C", "D"]
    },
    "safety_veto": {
      "type": "boolean"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "enum": ["low", "medium", "high"]
    },
    "status": {
      "enum": [
        "accepted",
        "accepted_with_constraints",
        "unresolved",
        "rejected",
        "postponed"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "safety_veto": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "consensus_level": {
            "enum": ["C", "D"]
          },
          "status": {
            "enum": ["unresolved", "rejected", "postponed"]
          }
        }
      }
    }
  ]
}

